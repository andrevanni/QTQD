{
  "version": 2,
  "crons": [
    {
      "path": "/api/v1/cron/acompanhamento-semanal",
      "schedule": "0 9 * * 1"
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend_cliente/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend_admin/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend_instalar/**",
      "use": "@vercel/static"
    },
    {
      "src": "shared/**",
      "use": "@vercel/static"
    },
    {
      "src": "service_icone.ico",
      "use": "@vercel/static"
    },
    {
      "src": "validar_fronts.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/cliente/sw.js",
      "dest": "/frontend_cliente/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/cliente/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/cliente/manifest.json",
      "dest": "/frontend_cliente/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/service_icone.ico",
      "dest": "/service_icone.ico"
    },
    {
      "src": "/cliente",
      "dest": "/frontend_cliente/index.html"
    },
    {
      "src": "/cliente/(.*)",
      "dest": "/frontend_cliente/$1"
    },
    {
      "src": "/admin",
      "dest": "/frontend_admin/index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/frontend_admin/$1"
    },
    {
      "src": "/instalar",
      "dest": "/frontend_instalar/index.html"
    },
    {
      "src": "/instalar/(.*)",
      "dest": "/frontend_instalar/$1"
    },
    {
      "src": "/shared/(.*)",
      "dest": "/shared/$1"
    },
    {
      "src": "/",
      "dest": "/validar_fronts.html"
    }
  ]
}
